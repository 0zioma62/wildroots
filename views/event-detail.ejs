<%- include('partials/header') %>

<main>
  <div class="page-hero">
    <h1><%= event.title %></h1>
    <% if (isPast) { %>
      <span class="badge past">This event has already taken place</span>
    <% } else { %>
      <span class="badge upcoming">Upcoming Event</span>
    <% } %>
    </div>

  <div class="event-detail-div">
    <div class="event-detail-card">
      <p class="event-date">📅 <%= event.event_date %></p>
      <p class="event-category">🏷️ <%= event.category.replace(/_/g, ' ') %></p>
      <p class="event-description"><%= event.description %></p>
      <a href="/events" class="btn-secondary">← Back to Events</a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>