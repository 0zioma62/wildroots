<%- include('partials/header') %>

<main>
  <div class="page-hero">
    <h1>Safari Spotter</h1>
    <p>Match the animals of the Savannah Plains — flip the cards to find the pairs!</p>
  </div>

  <div class="activity-section">
    <div class="game-info">
      <p>Attempts: <span id="attempts">0</span></p>
      <p>Matches: <span id="matches">0</span></p>
      <button id="restart-btn" class="btn-secondary">Restart Game</button>
    </div>
    <div id="game-grid" class="game-grid"></div>
    <div id="win-message" class="win-message hidden">
      🎉 Well done! You matched all the animals in <span id="final-attempts"></span> attempts!
    </div>
  </div>
</main>

<script src="/js/activity.js"></script>

<%- include('partials/footer') %>