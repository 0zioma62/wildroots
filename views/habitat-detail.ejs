<%- include('partials/header') %>

<main>
  <div class="page-hero">
    <h1><%= habitat.name %></h1>
    <p><%= habitat.description %></p>
  </div>

  <div class="experiences-section">
    <h2>Experiences & Exhibits</h2>
    <div id="experiences-grid" class="cards-grid">
      <% experiences.forEach(exp => { %>
        <div class="card">
          <span class="badge"><%= exp.type %></span>
          <h3><%= exp.name %></h3>
          <p><%= exp.description %></p>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="back-link">
    <a href="/habitats" class="btn-secondary">← Back to Habitats</a>
  </div>
</main>

<%- include('partials/footer') %>