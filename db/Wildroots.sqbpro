<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="Wildroots.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="1"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1617"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="events" custom_title="0" dock_id="1" table="4,6:mainevents"/><dock_state state="000000ff00000000fd0000000100000002000004f400000226fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000004f40000011e00ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="events" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="29"/><column index="2" value="257"/><column index="3" value="300"/><column index="4" value="171"/><column index="5" value="85"/><column index="6" value="241"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="experiences" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="29"/><column index="2" value="67"/><column index="3" value="195"/><column index="4" value="300"/><column index="5" value="93"/><column index="6" value="163"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="habitats" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="29"/><column index="2" value="140"/><column index="3" value="300"/><column index="4" value="70"/><column index="5" value="171"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">INSERT INTO events (title, description, category, event_date, image_url) VALUES
('Rainforest Night Safari', 'Experience the rainforest after dark with our expert guides leading you through the canopy by torchlight.', 'night_safari', '2026-07-15', 'images/night-safari.jpg'),
('Big Cat Conservation Talk', 'Leading wildlife expert Dr Sarah Collins discusses the global effort to protect endangered big cats.', 'guest_talk', '2026-08-10', 'images/big-cat-talk.jpg'),
('Family Reptile Day', 'A fun filled day for the whole family featuring reptile handling, face painting and keeper talks.', 'family_activity', '2026-09-20', 'images/reptile-day.jpg'),
('Autumn Wildlife Festival', 'Celebrate the beauty of autumn wildlife with special exhibits, live music and seasonal food stalls.', 'wildlife_festival', '2026-10-05', 'images/autumn-festival.jpg'),
('Elephant Conservation Workshop', 'Learn about elephant conservation efforts in Africa and how WildRoots supports them.', 'conservation_workshop', '2026-11-12', 'images/elephant-workshop.jpg'),
('Christmas Family Safari', 'A magical Christmas experience for the whole family with festive animal encounters and seasonal activities.', 'family_activity', '2026-12-20', 'images/christmas-safari.jpg'),
('Summer Savannah Festival', 'A spectacular celebration of African wildlife featuring drumming performances and safari experiences.', 'wildlife_festival', '2025-07-18', 'images/savannah-festival.jpg'),
('Nocturnal Creatures Night', 'Discover the secret lives of nocturnal animals on this after dark adventure through the park.', 'night_safari', '2025-09-14', 'images/nocturnal-night.jpg'),
('Snake Awareness Workshop', 'Expert herpetologist Dr James Webb leads this fascinating workshop on snake behaviour and conservation.', 'conservation_workshop', '2025-10-22', 'images/snake-workshop.jpg'),
('Halloween Spooky Safari', 'A frightfully fun Halloween event for families with spooky animal facts and themed activities.', 'family_activity', '2025-10-31', 'images/halloween-safari.jpg'),
('Primate Research Talk', 'World renowned primatologist Dr Lisa Park shares her groundbreaking research on orangutan behaviour.', 'guest_talk', '2025-11-08', 'images/primate-talk.jpg'),
('Spring Wildlife Festival', 'Welcome spring with a celebration of new life in the park featuring baby animal encounters.', 'wildlife_festival', '2024-03-21', 'images/spring-festival.jpg'),
('Junior Ranger Family Day', 'Kids can become junior rangers for the day, completing wildlife challenges across all three habitats.', 'family_activity', '2024-06-15', 'images/junior-ranger.jpg'),
('Rainforest Conservation Workshop', 'Join our rainforest experts to learn about deforestation and what we can do to help.', 'conservation_workshop', '2024-08-19', 'images/rainforest-workshop.jpg'),
('Winter Solstice Night Safari', 'Celebrate the longest night of the year with a magical guided tour of the park after dark.', 'night_safari', '2024-12-21', 'images/winter-safari.jpg');</sql><current_tab id="0"/></tab_sql></sqlb_project>
